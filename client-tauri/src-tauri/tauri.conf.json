{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VLan Gaming",
  "version": "1.0.0-1",
  "identifier": "com.lixin.vlan-gaming",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "VLan Gaming",
        "width": 900,
        "height": 600,
        "resizable": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "shortDescription": "虚拟局域网游戏联机工具",
    "longDescription": "VLan Gaming 是一款虚拟局域网游戏联机工具，通过服务器中继为玩家构建虚拟局域网环境，让不在同一网络下的玩家也能轻松进行局域网联机游戏。支持房间管理、实时聊天、管理员权限控制和低延迟数据转发。",
    "resources": [
      "../../wintun.dll"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "languages": ["SimpChinese"],
        "displayLanguageSelector": false
      }
    }
  }
}
